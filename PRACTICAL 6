#include <stdio.h>
#include <string.h>
#define TABLE_SIZE 10
char hashTable[TABLE_SIZE][20];
int hashFunction(char key[])
{
    int sum = 0;

    for(int i = 0; key[i] != '\0'; i++)
        sum += key[i];

    return sum % TABLE_SIZE;
}
int insertVehicle(char key[])
{
    int index = hashFunction(key);

    int start = index;

    while(strlen(hashTable[index]) != 0)
    {
        index = (index + 1) % TABLE_SIZE;

        if(index == start)
        {
            printf("Parking Full!\n");
            return -1;
        }
    }

    strcpy(hashTable[index], key);
    return index;
}

int main()
{
    int n;
    char vehicle[20];

    printf("Enter number of vehicles: ");
    scanf("%d",&n);

    for(int i = 0; i < n; i++)
    {
        printf("\nEnter Vehicle Registration Number: ");
        scanf("%s",vehicle);

        int spot = insertVehicle(vehicle);

        if(spot != -1)
            printf("Vehicle parked at Spot ID: %d\n", spot);
    }

    return 0;
}

